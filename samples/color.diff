@@ -0,0 +1,145 @@
+import { test, expect } from '../fixtures/api.fixture';
+
+const baseUrl = process.env.E2E_BASE_URL || 'https://e2e.reno.house';
+
+interface ScopeOfWorkDto {
+  id: string;
+  parentId: string;
+  name: string;
+  acronym: string;
+  level: string;
+  orderNumber: number;
+  color: string;
+}
+
+test.describe('Scope of Work color inheritance (API)', () => {
+  // Only run for primary user (Alice = admin)
+  test.beforeEach(({ testUser }, testInfo) => {
+    if (testUser === 'secondary') {
+      testInfo.skip();
+    }
+  });
+
+  test('new task inherits trade color via API', async ({ apiToken }) => {
+    const headers = {
+      Authorization: `Bearer ${apiToken}`,
+      'Content-Type': 'application/json',
+    };
+
+    // Create a trade with a specific color
+    const suffix = Date.now();
+    const tradeResponse = await fetch(`${baseUrl}/api/ScopeOfWork`, {
+      method: 'POST',
+      headers,
+      body: JSON.stringify({
+        parentId: 'ROOT',
+        name: `ColorTest-${suffix}`,
+        acronym: 'CT',
+        orderNumber: 100,
+        color: '#CC6600',
+      }),
+    });
+    expect(tradeResponse.status).toBe(201);
+    const trade: ScopeOfWorkDto = await tradeResponse.json();
+
+    // Create a task under that trade (send a different color — should be overridden)
+    const taskResponse = await fetch(`${baseUrl}/api/ScopeOfWork`, {
+      method: 'POST',
+      headers,
+      body: JSON.stringify({
+        parentId: trade.id,
+        name: `ColorTask-${suffix}`,
+        acronym: 'CK',
+        orderNumber: 1,
+        color: '#000000',
+      }),
+    });
+    expect(taskResponse.status).toBe(201);
+    const task: ScopeOfWorkDto = await taskResponse.json();
+
+    // Task should have the trade's color, not the one we sent
+    expect(task.color).toBe('#CC6600');
+
+    // Cleanup
+    await fetch(`${baseUrl}/api/ScopeOfWork/${trade.id}`, {
+      method: 'DELETE',
+      headers,
+    });
+  });
+
+  test('trade color change cascades to tasks via API', async ({ apiToken }) => {
+    const headers = {
+      Authorization: `Bearer ${apiToken}`,
+      'Content-Type': 'application/json',
+    };
+
+    // Create a trade
+    const suffix = Date.now();
+    const tradeResponse = await fetch(`${baseUrl}/api/ScopeOfWork`, {
+      method: 'POST',
+      headers,
+      body: JSON.stringify({
+        parentId: 'ROOT',
+        name: `CascadeTest-${suffix}`,
+        acronym: 'CS',
+        orderNumber: 101,
+        color: '#990000',
+      }),
+    });
+    expect(tradeResponse.status).toBe(201);
+    const trade: ScopeOfWorkDto = await tradeResponse.json();
+
+    // Create two tasks under the trade
+    const task1Resp = await fetch(`${baseUrl}/api/ScopeOfWork`, {
+      method: 'POST',
+      headers,
+      body: JSON.stringify({
+        parentId: trade.id,
+        name: `CascadeTask1-${suffix}`,
+        acronym: 'C1',
+        orderNumber: 1,
+      }),
+    });
+    const task2Resp = await fetch(`${baseUrl}/api/ScopeOfWork`, {
+      method: 'POST',
+      headers,
+      body: JSON.stringify({
+        parentId: trade.id,
+        name: `CascadeTask2-${suffix}`,
+        acronym: 'C2',
+        orderNumber: 2,
+      }),
+    });
+    expect(task1Resp.status).toBe(201);
+    expect(task2Resp.status).toBe(201);
+
+    // Update the trade's color
+    const updateResp = await fetch(`${baseUrl}/api/ScopeOfWork`, {
+      method: 'PUT',
+      headers,
+      body: JSON.stringify({
+        ...trade,
+        color: '#009933',
+      }),
+    });
+    expect(updateResp.status).toBe(200);
+
+    // Fetch all items and verify child tasks have the new color
+    const allResp = await fetch(`${baseUrl}/api/ScopeOfWork`, {
+      headers: { Authorization: `Bearer ${apiToken}` },
+    });
+    const allItems: ScopeOfWorkDto[] = await allResp.json();
+    const childTasks = allItems.filter(i => i.parentId === trade.id);
+
+    expect(childTasks).toHaveLength(2);
+    for (const task of childTasks) {
+      expect(task.color).toBe('#009933');
+    }
+
+    // Cleanup
+    await fetch(`${baseUrl}/api/ScopeOfWork/${trade.id}`, {
+      method: 'DELETE',
+      headers,
+    });
+  });
+});
